# ── Local Development ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000

# SQLite (local)
DATABASE_URL="file:./prisma/dev.db"

# JWT – change this to a long random string in production
JWT_SECRET=your_jwt_secret_here_change_this

# CORS – frontend origin (React dev server)
CORS_ORIGIN=http://localhost:3000

# Python ML service URL (start ml_service.py locally)
ML_SERVICE_URL=http://localhost:5001

# ── Production (Render.com) ───────────────────────────────────────────────────
# DATABASE_URL="postgresql://user:password@host:5432/cornleaf"
# JWT_SECRET=<generated by Render>
# PORT=10000
# ML_SERVICE_URL=https://corn-leaf-ml.onrender.com
# CORS_ORIGIN=*
