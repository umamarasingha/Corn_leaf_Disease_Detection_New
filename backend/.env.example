# ─── Local development ────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.

# Node environment
NODE_ENV=development

# Server port
PORT=8000

# SQLite database (local dev)
DATABASE_URL="file:./prisma/dev.db"

# JWT secrets – use strong random strings in production
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this

# CORS – frontend origin
CORS_ORIGIN=http://localhost:3000

# ML inference service URL (optional – leave blank to use built-in tfjs-node or mock)
# ML_SERVICE_URL=http://localhost:5001

# ─── Railway / Production overrides ──────────────────────────────────────────
# Set these as Railway environment variables in the dashboard:
#
# DATABASE_URL=file:/app/data/prod.db          ← volume mounted at /app/data
# JWT_SECRET=<random 64-char string>
# JWT_REFRESH_SECRET=<random 64-char string>
# CORS_ORIGIN=https://your-frontend-domain.com
# NODE_ENV=production
# PORT=8000                                     ← Railway sets this automatically
